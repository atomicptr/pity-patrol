{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Pity Patrol Configuration",
    "type": "object",
    "properties": {
        "user-agent": {
            "type": "string",
            "description": "Custom user agent string. Leave empty for default Chrome agent."
        },
        "enable-scheduler": {
            "type": "boolean",
            "default": false,
            "description": "If true, runs jobs automatically at reset times."
        },
        "accounts": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "game": {
                        "type": "string",
                        "enum": [
                            "endfield",
                            "genshin",
                            "starrail",
                            "honkai",
                            "zzz",
                            "themis"
                        ]
                    },
                    "identifier": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Label used in logs and reports."
                    },
                    "checkin-offset": {
                        "type": [
                            "integer",
                            "null"
                        ],
                        "description": "Delay in minutes for the scheduler."
                    }
                },
                "required": [
                    "game"
                ],
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "game": {
                                    "const": "endfield"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "credentials": {
                                    "type": "string"
                                },
                                "sk-game-role": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "credentials",
                                "sk-game-role"
                            ]
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "game": {
                                    "enum": [
                                        "genshin",
                                        "starrail",
                                        "honkai",
                                        "zzz",
                                        "themis"
                                    ]
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "cookie": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "cookie"
                            ]
                        }
                    }
                ]
            }
        },
        "reporters": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "discord"
                        ]
                    },
                    "on": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "success",
                                "failure"
                            ]
                        }
                    },
                    "webhook-url": {
                        "type": "string"
                    }
                },
                "required": [
                    "type"
                ],
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "type": {
                                    "enum": [
                                        "discord"
                                    ]
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "webhook-url": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "webhook-url"
                            ]
                        }
                    }
                ]
            }
        }
    }
}
